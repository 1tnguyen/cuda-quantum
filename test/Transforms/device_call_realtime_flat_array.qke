// RUN: cudaq-opt -pass-pipeline='builtin.module(canonicalize,distributed-device-call{realtime=1},cse,canonicalize)' %s | FileCheck %s

func.func @flatArrayKernel(%arg0 : !cc.ptr<i32>, %arg1 : i64, %arg2 : i32) -> i32 attributes {"cudaq-entrypoint", "cudaq-kernel", no_this} {
  %0 = cc.device_call @sumIntArray(%arg0, %arg1, %arg2) : (!cc.ptr<i32>, i64, i32) -> i32
  return %0 : i32
}

func.func private @sumIntArray(!cc.ptr<i32>, i64, i32) -> i32 attributes {"cudaq-devicecall"}

// clang-format off
// CHECK-LABEL: func.func @flatArrayKernel(
// CHECK-SAME:    %[[VALUES:.*]]: !cc.ptr<i32>, %[[COUNT:.*]]: i64, %[[BIAS:.*]]: i32) -> i32
// CHECK-DAG:     %[[FUNCTION_ID:.*]] = arith.constant -{{[0-9]+}} : i32
// CHECK-DAG:     %[[COUNT_BYTES:.*]] = arith.muli %[[COUNT]], {{.*}} : i64
// CHECK:         call @__cudaq_device_call_acquire_realtime_frame({{.*}}, %[[FUNCTION_ID]],
// CHECK:         cc.store %[[COUNT]], {{.*}} : !cc.ptr<i64>
// CHECK:         %[[VALUES_ARRAY:.*]] = cc.cast %[[VALUES]] : (!cc.ptr<i32>) -> !cc.ptr<!cc.array<i32 x ?>>
// CHECK:         cc.loop while
// CHECK:         ^bb0(%[[INDEX:.*]]: i64):
// CHECK:           %[[ELEMENT_PTR:.*]] = cc.compute_ptr %[[VALUES_ARRAY]][%[[INDEX]]] : (!cc.ptr<!cc.array<i32 x ?>>, i64) -> !cc.ptr<i32>
// CHECK:           %[[ELEMENT:.*]] = cc.load %[[ELEMENT_PTR]] : !cc.ptr<i32>
// CHECK:           cc.store %[[ELEMENT]], {{.*}} : !cc.ptr<i32>
// CHECK:         }
// CHECK:         cc.store %[[BIAS]], {{.*}} : !cc.ptr<i32>
// CHECK:         call @__cudaq_device_call_dispatch_realtime_frame
// CHECK:         call @__cudaq_device_call_safely_release_realtime_frame
// CHECK:         return {{.*}} : i32
// CHECK:       }
// clang-format on
