// RUN: not cudaq-opt -pass-pipeline='builtin.module(distributed-device-call{realtime=1})' %s 2>&1 | FileCheck %s

func.func @kernel(%arg0: !cc.ptr<i32>) attributes {"cudaq-entrypoint", "cudaq-kernel", no_this} {
  cc.device_call @incrementInt(%arg0) : (!cc.ptr<i32>) -> ()
  return
}

func.func private @incrementInt(!cc.ptr<i32>) attributes {"cudaq-devicecall"}

// CHECK: error: 'cc.device_call' op realtime device_call lowering does not support raw pointer arguments
