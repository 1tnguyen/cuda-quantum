// Qubit mapping of nested rolled (kept) value-semantics loops. Both loops stay
// rolled; the mapper recurses into the inner loop and routes its body (a mapped
// inner loop is layout-preserving, so the outer loop needs no swaps). The
// two-qubit gates live in the innermost loop.

// clang-format off
// RUN: cudaq-opt --cc-loop-unroll --canonicalize %s > %t.orig.mlir
// RUN: cudaq-opt '--qubit-mapping=device=star(3)' %s | FileCheck --check-prefix=MAP %s
// RUN: cudaq-opt '--qubit-mapping=device=star(3)' %s | cudaq-opt --cc-loop-unroll --canonicalize | CircuitCheck --up-to-mapping %t.orig.mlir
// clang-format on

module {
  quake.wire_set @wires[2147483647] attributes {sym_visibility = "private"}
  func.func @__nvqpp__mlirgen__function_kernel._Z6kernelv() -> i1 attributes {"cudaq-entrypoint", "cudaq-kernel", no_this} {
    %c1_i32 = arith.constant 1 : i32
    %c2_i32 = arith.constant 2 : i32
    %c3_i32 = arith.constant 3 : i32
    %c0_i32 = arith.constant 0 : i32
    %0 = quake.borrow_wire @wires[0] : !quake.wire
    %1 = quake.borrow_wire @wires[1] : !quake.wire
    %2 = quake.borrow_wire @wires[2] : !quake.wire
    %3:4 = cc.loop while ((%arg0 = %0, %arg1 = %1, %arg2 = %2, %arg3 = %c0_i32) -> (!quake.wire, !quake.wire, !quake.wire, i32)) {
      %13 = arith.cmpi slt, %arg3, %c3_i32 : i32
      cc.condition %13(%arg0, %arg1, %arg2, %arg3 : !quake.wire, !quake.wire, !quake.wire, i32)
    } do {
    ^bb0(%arg0: !quake.wire, %arg1: !quake.wire, %arg2: !quake.wire, %arg3: i32):
      %13:4 = cc.loop while ((%arg4 = %arg0, %arg5 = %arg1, %arg6 = %arg2, %arg7 = %c0_i32) -> (!quake.wire, !quake.wire, !quake.wire, i32)) {
        %14 = arith.cmpi slt, %arg7, %c2_i32 : i32
        cc.condition %14(%arg4, %arg5, %arg6, %arg7 : !quake.wire, !quake.wire, !quake.wire, i32)
      } do {
      ^bb0(%arg4: !quake.wire, %arg5: !quake.wire, %arg6: !quake.wire, %arg7: i32):
        %14:2 = quake.x [%arg4] %arg5 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
        %15:2 = quake.x [%14#1] %arg6 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
        cc.continue %14#0, %15#0, %15#1, %arg7 : !quake.wire, !quake.wire, !quake.wire, i32
      } step {
      ^bb0(%arg4: !quake.wire, %arg5: !quake.wire, %arg6: !quake.wire, %arg7: i32):
        %14 = arith.addi %arg7, %c1_i32 : i32
        cc.continue %arg4, %arg5, %arg6, %14 : !quake.wire, !quake.wire, !quake.wire, i32
      }
      cc.continue %13#0, %13#1, %13#2, %arg3 : !quake.wire, !quake.wire, !quake.wire, i32
    } step {
    ^bb0(%arg0: !quake.wire, %arg1: !quake.wire, %arg2: !quake.wire, %arg3: i32):
      %13 = arith.addi %arg3, %c1_i32 : i32
      cc.continue %arg0, %arg1, %arg2, %13 : !quake.wire, !quake.wire, !quake.wire, i32
    }
    %measOut, %wires = quake.mz %3#0 : (!quake.wire) -> (!cc.measure_handle, !quake.wire)
    %4 = quake.discriminate %measOut : (!cc.measure_handle) -> i1
    %5 = cc.cast unsigned %4 : (i1) -> i32
    %measOut_0, %wires_1 = quake.mz %3#1 : (!quake.wire) -> (!cc.measure_handle, !quake.wire)
    %6 = quake.discriminate %measOut_0 : (!cc.measure_handle) -> i1
    %7 = cc.cast unsigned %6 : (i1) -> i32
    %8 = arith.xori %5, %7 : i32
    %measOut_2, %wires_3 = quake.mz %3#2 : (!quake.wire) -> (!cc.measure_handle, !quake.wire)
    %9 = quake.discriminate %measOut_2 : (!cc.measure_handle) -> i1
    %10 = cc.cast unsigned %9 : (i1) -> i32
    %11 = arith.xori %8, %10 : i32
    %12 = arith.cmpi ne, %11, %c0_i32 : i32
    return %12 : i1
  }
}

