// RUN: cudaq-opt --assign-wire-indices --qubit-mapping=device=file\(%S/Inputs/qm-disconnected-mapping.txt\) %s | FileCheck %s

// The device described by the topology file has 10 physical qubits but only a
// single edge connecting qubits 5 and 6. The two active virtual qubits used by
// this kernel must therefore be placed on the only connected component large
// enough to hold them: {5, 6}. A naive identity placement would put them on
// physical qubits 0 and 1, which are not connected.

quake.wire_set @wires[2147483647]

func.func @bell() attributes {"cudaq-entrypoint", "cudaq-kernel"} {
  %0 = quake.null_wire
  %1 = quake.null_wire
  %2 = quake.h %0 : (!quake.wire) -> !quake.wire
  %3:2 = quake.x [%2] %1 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  %m0, %4 = quake.mz %3#0 : (!quake.wire) -> (!quake.measure, !quake.wire)
  %m1, %5 = quake.mz %3#1 : (!quake.wire) -> (!quake.measure, !quake.wire)
  quake.sink %4 : !quake.wire
  quake.sink %5 : !quake.wire
  return
}

// The mapped wire set spans all 10 physical qubits, but its only adjacency is
// the edge between physical qubits 5 and 6.
// CHECK: quake.wire_set @mapped_wireset[10] adjacency sparse<{{\[\[}}5, 6], [6, 5]], true>

// The two virtual qubits must be placed on the connected component {5, 6}.
// CHECK: func.func @bell() attributes {{.*}}mapping_v2p = [5, 6]

// The borrowed wires must reference the physical qubits they were placed on
// (5 and 6), and the CX must act directly on them without any inserted SWAPs.
// CHECK:         %[[VAL_0:.*]] = quake.borrow_wire @mapped_wireset[5] : !quake.wire
// CHECK:         %[[VAL_1:.*]] = quake.borrow_wire @mapped_wireset[6] : !quake.wire
// CHECK:         %[[VAL_2:.*]] = quake.h %[[VAL_0]] : (!quake.wire) -> !quake.wire
// CHECK:         %[[VAL_3:.*]]:2 = quake.x {{\[}}%[[VAL_2]]] %[[VAL_1]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
// CHECK-NOT:     quake.swap
