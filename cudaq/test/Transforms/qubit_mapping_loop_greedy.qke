// Global greedy placement of a value-semantics circuit whose gates live inside
// a rolled (kept) cc.loop. The loop body applies x(a,b) then x(b,c), so b
// interacts with both a and c. Greedy placement puts the highest-degree virtual
// qubit (b) on the star center (physical 0) and a, c on the leaves, which makes
// both controlled-x gates adjacent: the body needs *zero* routing swaps, unlike
// the identity layout (see qubit_mapping_loop.qke, which needs a swap and a
// restoring swap). The placement is applied to every borrow (mapping_v2p =
// [1, 0, 2]) and the loop stays rolled.

// clang-format off
// RUN: cudaq-opt --cc-loop-unroll --canonicalize %s > %t.orig.mlir
// RUN: cudaq-opt '--qubit-mapping=device=star(3) placement=greedy' %s | FileCheck --check-prefix=GREEDY %s
// Routing is correct iff unrolling the mapped circuit equals unrolling the
// original, up to a qubit permutation:
// RUN: cudaq-opt '--qubit-mapping=device=star(3) placement=greedy' %s | cudaq-opt --cc-loop-unroll --canonicalize | CircuitCheck --up-to-mapping %t.orig.mlir
// clang-format on

module {
  quake.wire_set @wires[2147483647] attributes {sym_visibility = "private"}
  func.func @__nvqpp__mlirgen__function_kernel._Z6kernelv() -> i1 attributes {"cudaq-entrypoint", "cudaq-kernel", no_this} {
    %c1_i32 = arith.constant 1 : i32
    %c4_i32 = arith.constant 4 : i32
    %c0_i32 = arith.constant 0 : i32
    %0 = quake.borrow_wire @wires[0] : !quake.wire
    %1 = quake.borrow_wire @wires[1] : !quake.wire
    %2 = quake.borrow_wire @wires[2] : !quake.wire
    %3:4 = cc.loop while ((%arg0 = %0, %arg1 = %1, %arg2 = %2, %arg3 = %c0_i32) -> (!quake.wire, !quake.wire, !quake.wire, i32)) {
      %13 = arith.cmpi slt, %arg3, %c4_i32 : i32
      cc.condition %13(%arg0, %arg1, %arg2, %arg3 : !quake.wire, !quake.wire, !quake.wire, i32)
    } do {
    ^bb0(%arg0: !quake.wire, %arg1: !quake.wire, %arg2: !quake.wire, %arg3: i32):
      %13:2 = quake.x [%arg0] %arg1 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
      %14:2 = quake.x [%13#1] %arg2 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
      cc.continue %13#0, %14#0, %14#1, %arg3 : !quake.wire, !quake.wire, !quake.wire, i32
    } step {
    ^bb0(%arg0: !quake.wire, %arg1: !quake.wire, %arg2: !quake.wire, %arg3: i32):
      %13 = arith.addi %arg3, %c1_i32 : i32
      cc.continue %arg0, %arg1, %arg2, %13 : !quake.wire, !quake.wire, !quake.wire, i32
    }
    %measOut, %wires = quake.mz %3#0 : (!quake.wire) -> (!cc.measure_handle, !quake.wire)
    %4 = quake.discriminate %measOut : (!cc.measure_handle) -> i1
    %5 = cc.cast unsigned %4 : (i1) -> i32
    %measOut_0, %wires_1 = quake.mz %3#1 : (!quake.wire) -> (!cc.measure_handle, !quake.wire)
    %6 = quake.discriminate %measOut_0 : (!cc.measure_handle) -> i1
    %7 = cc.cast unsigned %6 : (i1) -> i32
    %8 = arith.xori %5, %7 : i32
    %measOut_2, %wires_3 = quake.mz %3#2 : (!quake.wire) -> (!cc.measure_handle, !quake.wire)
    %9 = quake.discriminate %measOut_2 : (!cc.measure_handle) -> i1
    %10 = cc.cast unsigned %9 : (i1) -> i32
    %11 = arith.xori %8, %10 : i32
    %12 = arith.cmpi ne, %11, %c0_i32 : i32
    return %12 : i1
  }
}

