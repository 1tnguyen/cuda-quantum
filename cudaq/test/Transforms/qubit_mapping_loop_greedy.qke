// GREEDY:             %[[X_0:.*]]:2 = quake.x {{\[}}%[[VAL_4]]] %[[VAL_5]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
// GREEDY:             %[[X_1:.*]]:2 = quake.x {{\[}}%[[X_0]]#1] %[[VAL_6]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
// GREEDY:             cc.continue %[[X_0]]#0, %[[X_1]]#0, %[[X_1]]#1, %[[VAL_7]] : !quake.wire, !quake.wire, !quake.wire, i32
