// GREEDY:         quake.wire_set @wires[2147483647] attributes {sym_visibility = "private"}
// GREEDY-LABEL:   func.func @__nvqpp__mlirgen__function_kernel._Z6kernelv() -> i1 attributes {"cudaq-entrypoint", "cudaq-kernel", mapping_v2p = [1, 0, 2], no_this} {
// GREEDY:           %[[CONSTANT_0:.*]] = arith.constant 1 : i32
